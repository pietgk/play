{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": []
  },
  "include": ["src/**/*.ts", "select/src/**/*.ts"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "select/src/**/*.spec.ts",
    "select/src/**/*.test.ts",
    "**/*.stories.ts",
    "**/*.stories.js"
  ]
}
