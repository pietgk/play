# OpenAI / Codex authentication — choose one:
#
#   Subscription (default for this repo): leave OPENAI_KEY empty.
#   Codex will authenticate via ~/.codex/auth.json, which is bind-mounted
#   read-only into the container (see .sandcastle/main.mts).
#   Run `codex login` on the host once to establish those credentials.
#
#   API key: set OPENAI_KEY=sk-... to bypass subscription auth.
#
OPENAI_KEY=

# GitHub fine-grained personal access token.
# Required permissions for pietgk/play: Issues (Read and write), Metadata (Read).
# Create one at: https://github.com/settings/personal-access-tokens/new
GH_TOKEN=

# Nx Cloud workspace access token (OPTIONAL) — lets the agent share the same
# remote cache as CI. Without it the agent still works; it just runs uncached.
# Any key listed here is forwarded into the container by Sandcastle (see
# resolveEnv in @ai-hero/sandcastle); the value falls back to the host env var
# of the same name if left blank. Use the SAME workspace token as the
# NX_CLOUD_ACCESS_TOKEN GitHub Actions secret (cloud.nx.app → workspace →
# Access Tokens — a read-write CI token, not your personal `nx login` token).
NX_CLOUD_ACCESS_TOKEN=
