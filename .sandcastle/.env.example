# OpenAI / Codex authentication — choose one:
#
#   Subscription (default for this repo): leave OPENAI_KEY empty.
#   Codex will authenticate via ~/.codex/auth.json, which is bind-mounted
#   read-only into the container (see .sandcastle/main.mts).
#   Run `codex login` on the host once to establish those credentials.
#
#   API key: set OPENAI_KEY=sk-... to bypass subscription auth.
#
OPENAI_KEY=

# GitHub fine-grained personal access token.
# Required permissions for pietgk/play: Issues (Read and write), Metadata (Read).
# Create one at: https://github.com/settings/personal-access-tokens/new
GH_TOKEN=
