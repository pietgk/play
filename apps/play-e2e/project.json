{
  "name": "play-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/play-e2e/src",
  "implicitDependencies": ["play"],
  "// targets": "to see all targets run: nx show project play-e2e --web",
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "projects": ["play"],
          "target": "build"
        }
      ],
      "options": {
        "command": "node apps/play-e2e/run-e2e.mjs"
      }
    }
  }
}
